#!/usr/bin/env bash
# Thin wrapper: forwards to scripts/slide_build_with_setup.sh (same behavior).
# From repo root:  bin/deck --template templates/T.pptx --input examples/spec.json

set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
exec "$ROOT/scripts/slide_build_with_setup.sh" "$@"
