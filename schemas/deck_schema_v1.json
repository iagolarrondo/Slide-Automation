{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/deck_schema_v1.json",
  "title": "Deck Schema v1",
  "type": "object",
  "required": ["deck_title", "slides"],
  "additionalProperties": false,
  "properties": {
    "deck_title": {
      "type": "string",
      "minLength": 1
    },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/slide"
      }
    }
  },
  "$defs": {
    "slide": {
      "type": "object",
      "required": ["type", "title"],
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "cover",
            "agenda",
            "divider",
            "standard_1_block",
            "standard_2_block",
            "standard_3_block"
          ]
        },
        "title": {
          "type": "string"
        },
        "subtitle": {
          "type": "string"
        },
        "items": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "section": {
          "type": "string"
        },
        "blocks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/block"
          }
        }
      }
    },
    "block": {
      "type": "object",
      "required": ["heading", "body"],
      "additionalProperties": true,
      "properties": {
        "heading": {
          "type": "string"
        },
        "body": {
          "type": "string"
        }
      }
    }
  }
}
